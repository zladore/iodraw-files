{"root":{"data":{"id":"dhlxr7q2s8g0","created":1775464831794,"text":"OV-OAD"},"children":[{"data":{"id":"dhlxrb5j24g0","created":1775464839258,"text":"视觉编码器","layout":null},"children":[{"data":{"id":"dhlxrkzhw4w0","created":1775464860661,"text":"block1：distant neighboring-frame transformer（灰色）","layout":null},"children":[{"data":{"id":"dhlxtk81ko00","created":1775465015730,"text":"由Transformer解码器单元组成\n作用：将neighboring tokens和distant past tokens 作为输入"},"children":[]},{"data":{"id":"dhlxyyoqtm80","created":1775465439035,"text":"补充：tokens的提取："},"children":[{"data":{"id":"dhlxz6lxtns0","created":1775465456280,"text":"分支主题"},"children":[{"data":{"id":"dhlxzbumcc00","created":1775465467689,"text":"训练和推理时，先把原始视频重采样到 4 FPS"},"children":[]}]}]}]},{"data":{"id":"dhlxscu0qao0","created":1775464921280,"text":"block2：action clustering（黄色）","layout":null},"children":[]}]},{"data":{"id":"dhlxrdepbw00","created":1775464844167,"text":"文本编码器","layout":null},"children":[]}]},"template":"right","theme":"fresh-blue","version":"1.4.43"}